# Gateway (@altdream/gateway) — copy to .env and adjust
GATEWAY_API_KEY=generate-a-long-random-secret
PORT=8787
DATABASE_PATH=./data/altdream.db
BLOB_DIR=./data/blobs
MAX_UPLOAD_BYTES=52428800
# Optional: Kubo HTTP API (no trailing slash). Compose profile "ipfs" sets this to http://ipfs:5001
IPFS_API_URL=
# Comma-separated browser origins for CORS
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# MIME allowlist for POST /v1/offload (comma-separated)
ALLOWED_MIMES=image/jpeg,image/png,image/webp,image/gif,video/mp4,application/octet-stream
